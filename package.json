{
  "name": "tcg-viewer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cards:fetch": "node scripts/fetch-card-data.mjs",
    "cards:generate": "node scripts/generate-card-data.mjs",
    "cards:images": "node scripts/download-images.mjs",
    "cards:images:cdn": "node scripts/download-images.mjs --cdn",
    "cards:all": "npm run cards:fetch && npm run cards:generate",
    "r2:upload": "node scripts/upload-to-r2.mjs",
    "gundam:fetch": "node scripts/fetch-gundam-data.mjs",
    "gundam:generate": "node scripts/generate-gundam-data.mjs",
    "gundam:images": "node scripts/download-gundam-images.mjs",
    "gundam:all": "npm run gundam:fetch && npm run gundam:images && npm run gundam:generate",
    "gundam:r2": "node scripts/upload-to-r2.mjs --dir=public/cards-gundam --prefix=cards/gundam --ext=webp",
    "dbs:fetch": "node scripts/fetch-dbs-data.mjs",
    "dbs:generate": "node scripts/generate-dbs-data.mjs",
    "dbs:images": "node scripts/download-dbs-images.mjs",
    "dbs:all": "npm run dbs:fetch && npm run dbs:images && npm run dbs:generate",
    "dbs:r2": "node scripts/upload-to-r2.mjs --dir=public/cards-dbs --prefix=cards/dbs --ext=webp",
    "digimon:fetch": "node scripts/fetch-digimon-data.mjs",
    "digimon:generate": "node scripts/generate-digimon-data.mjs",
    "digimon:images": "node scripts/download-digimon-images.mjs",
    "digimon:all": "npm run digimon:fetch && npm run digimon:images && npm run digimon:generate",
    "digimon:r2": "node scripts/upload-to-r2.mjs --dir=public/cards-digimon --prefix=cards/digimon --ext=png",
    "pokemon:fetch": "node scripts/fetch-pokemon-data.mjs",
    "pokemon:generate": "node scripts/generate-pokemon-bundle.mjs",
    "pokemon:images": "node scripts/download-pokemon-images.mjs",
    "pokemon:all": "npm run pokemon:fetch && npm run pokemon:images && npm run pokemon:generate",
    "pokemon:r2": "node scripts/upload-to-r2.mjs --dir=public/cards-pokemon --prefix=cards/pokemon --ext=webp"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.13.6",
    "@vercel/analytics": "^2.0.1",
    "gsap": "^3.15.0",
    "lenis": "^1.2.3",
    "lucide-react": "^1.8.0",
    "motion": "^12.7.3",
    "next": "^15.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.84.0"
  }
}
